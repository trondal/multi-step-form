{
  "name": "multi-step-form",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "prettier": "prettier --check 'index.html' '*.config.js' '{api,src}/**/*{js,jsx,ts,tsx,md,html,css,scss}'",
    "prettier:write": "prettier --write 'index.html' '*.config.js' '{api,src}/**/*{js,jsx,ts,tsx,md,html,css,scss}'",
    "test": "vitest",
    "tsc": "npx tsc --noEmit"
  },
  "dependencies": {
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.1",
    "@fontsource/roboto": "5.2.10",
    "@hookform/resolvers": "5.2.2",
    "@mantine/hooks": "8.3.15",
    "@mui/icons-material": "7.3.8",
    "@mui/material": "7.3.8",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "7.71.2",
    "react-router-dom": "7.13.1",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "9.39.2",
    "@hookform/devtools": "4.4.0",
    "@types/node": "25.2.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react-swc": "4.2.3",
    "@vitest/eslint-plugin": "1.6.9",
    "eslint": "9.39.2",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "globals": "17.3.0",
    "typescript-eslint": "8.56.1",
    "vite": "7.3.1",
    "vitest": "4.0.18"
  },
  "prettier": {
    "singleQuote": true,
    "trailingComma": "none",
    "arrowParens": "always"
  }
}
