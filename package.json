{
  "name": "multi-step-form",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n web,api -c auto \"vite\" \"tsx watch src/api/server.ts\"",
    "dev:web": "vite",
    "dev:api": "tsx watch src/api/server.ts",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "prettier": "prettier --check 'index.html' '*.config.js' '{api,src}/**/*{js,jsx,ts,tsx,md,html,css,scss}'",
    "prettier:write": "prettier --write 'index.html' '*.config.js' '{api,src}/**/*{js,jsx,ts,tsx,md,html,css,scss}'",
    "test": "vitest",
    "tsc": "npx tsc --noEmit"
  },
  "dependencies": {
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.1",
    "@fontsource/roboto": "5.2.10",
    "@hookform/resolvers": "5.2.2",
    "@mui/icons-material": "7.3.9",
    "@mui/material": "7.3.9",
    "@tanstack/react-query": "5.90.21",
    "@tanstack/react-query-devtools": "5.91.3",
    "axios": "1.13.6",
    "better-sqlite3": "12.6.2",
    "cors": "2.8.6",
    "express": "5.2.1",
    "multer": "2.1.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "7.71.2",
    "react-router-dom": "7.13.1",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "9.39.2",
    "@hookform/devtools": "4.4.0",
    "@tanstack/eslint-plugin-query": "5.91.4",
    "@types/better-sqlite3": "7.6.13",
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "@types/multer": "2.1.0",
    "@types/node": "25.3.5",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react-swc": "4.2.3",
    "@vitest/eslint-plugin": "1.6.9",
    "concurrently": "9.2.1",
    "eslint": "9.39.2",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "globals": "17.4.0",
    "tsx": "4.21.0",
    "typescript-eslint": "8.56.1",
    "vite": "7.3.1",
    "vitest": "4.0.18"
  },
  "prettier": {
    "singleQuote": true,
    "trailingComma": "none",
    "arrowParens": "always"
  }
}
